# For pipeline and API (local and Vercel). Set in Vercel project Environment Variables for production.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Supabase (client uses NEXT_PUBLIC_*; backend uses SUPABASE_SERVICE_ROLE_KEY and SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL for writes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest: set INNGEST_DEV=1 for local dev (backend registers with Inngest dev server)
INNGEST_DEV=1

# Webshare proxy for YouTube transcript fetching (optional). Get credentials from https://dashboard.webshare.io/proxy/settings
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
